---
import Card from '../ui/Card.astro';

interface Props {
  title: string;
  slug: string;
  excerpt?: string;
  published_at?: string;
  featured_image?: { url?: string; sizes?: { card?: { url: string } } };
}
const { title, slug, excerpt, published_at, featured_image } = Astro.props;
const img = featured_image?.sizes?.card?.url || featured_image?.url;
const dateStr = published_at ? new Date(published_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) : '';
---

<Card href={`/berita/${slug}`} class="article-card">
  {img && (
    <div class="article-img">
      <img src={img} alt={title} loading="lazy" />
    </div>
  )}
  <div class="article-body">
    {dateStr && <time class="article-date">{dateStr}</time>}
    <h3>{title}</h3>
    {excerpt && <p class="article-excerpt">{excerpt}</p>}
  </div>
</Card>

<style>
  .article-img {
    border-radius: var(--radius);
    overflow: hidden;
    margin-bottom: 1rem;
    aspect-ratio: 16/9;
  }
  .article-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }
  .article-card:hover .article-img img {
    transform: scale(1.05);
  }
  .article-date {
    font-size: 0.8rem;
    color: var(--color-accent);
    font-weight: 500;
  }
  .article-body h3 {
    font-size: 1.05rem;
    margin: 0.5rem 0;
  }
  .article-excerpt {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
