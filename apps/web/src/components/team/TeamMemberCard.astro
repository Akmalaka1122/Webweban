---
import Card from '../ui/Card.astro';

interface Props {
  name: string;
  slug: string;
  role?: string;
  department?: string;
  photo?: { url?: string; sizes?: { card?: { url: string } } };
}
const { name, slug, role, department, photo } = Astro.props;
const img = photo?.sizes?.card?.url || photo?.url;
const initials = name.split(' ').map(w => w[0]).join('').slice(0, 2).toUpperCase();
---

<Card href={`/tim/${slug}`} class="team-card">
  <div class="team-avatar">
    {img ? (
      <img src={img} alt={name} loading="lazy" />
    ) : (
      <span class="team-initials">{initials}</span>
    )}
  </div>
  <h3>{name}</h3>
  {role && <p class="team-role">{role}</p>}
  {department && <span class="team-dept">{department}</span>}
</Card>

<style>
  .team-card {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .team-avatar {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    overflow: hidden;
    background: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
  }
  .team-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .team-initials {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-accent);
  }
  .team-card h3 {
    font-size: 1rem;
  }
  .team-role {
    font-size: 0.85rem;
    color: var(--color-accent);
    margin-top: 0.25rem;
  }
  .team-dept {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: 0.25rem;
  }
</style>
