---
interface Props {
  games?: string[];
  active?: string;
}
const { games = ['Semua', 'Mobile Legends', 'Free Fire', 'PUBG Mobile', 'Valorant'], active = 'Semua' } = Astro.props;
---

<div class="event-filters" role="group" aria-label="Filter berdasarkan game">
  {games.map((game) => (
    <a
      href={game === 'Semua' ? '/event' : `/event?game=${encodeURIComponent(game)}`}
      class:list={['filter-chip', { active: active === game }]}
    >
      {game}
    </a>
  ))}
</div>

<style>
  .event-filters {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }
  .filter-chip {
    padding: 0.5rem 1rem;
    font-size: 0.85rem;
    font-weight: 500;
    border-radius: 999px;
    background: var(--color-glass);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    transition: all 0.2s;
    text-decoration: none;
  }
  .filter-chip:hover,
  .filter-chip.active {
    background: rgba(249, 115, 22, 0.15);
    color: var(--color-accent);
    border-color: rgba(249, 115, 22, 0.3);
  }
</style>
