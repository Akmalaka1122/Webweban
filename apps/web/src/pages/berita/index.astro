---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/brand/Navbar.astro';
import Footer from '../../components/brand/Footer.astro';
import ArticleCard from '../../components/news/ArticleCard.astro';
import { getArticles } from '../../lib/cms';

const page = Number(Astro.url.searchParams.get('page')) || 1;
let articles: any[] = [];
try {
  const res = await getArticles({ limit: 12 });
  articles = res.docs || [];
} catch {}
---

<BaseLayout title="Berita" description="Berita terbaru dari RIKAS INDO TECHNOLOGY — update event, komunitas, dan esports Jawa Tengah">
  <Navbar slot="header" />

  <section class="section">
    <div class="container">
      <h1>Berita <span class="text-accent">RIKAS</span></h1>
      <p class="mt-1">Update terbaru dari komunitas esports kami.</p>

      {articles.length === 0 ? (
        <div class="empty-state mt-4">
          <p>Belum ada berita yang dipublikasikan.</p>
        </div>
      ) : (
        <div class="articles-grid mt-4">
          {articles.map((a) => (
            <ArticleCard
              title={a.title}
              slug={a.slug}
              excerpt={a.excerpt}
              published_at={a.published_at}
              featured_image={a.featured_image}
            />
          ))}
        </div>
      )}
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .articles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .empty-state {
    text-align: center;
    padding: 4rem 1rem;
    color: var(--color-text-muted);
  }
  @media (max-width: 1024px) {
    .articles-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .articles-grid { grid-template-columns: 1fr; }
  }
</style>
