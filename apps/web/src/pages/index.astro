---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/brand/Navbar.astro';
import Footer from '../components/brand/Footer.astro';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
import Badge from '../components/ui/Badge.astro';

const services = [
  {
    title: 'Event Esports',
    description: 'Penyelenggaraan turnamen dan kompetisi esports profesional di Jawa Tengah.',
    icon: '🏆',
  },
  {
    title: 'Talent Management',
    description: 'Pengelolaan dan pengembangan bakat esports untuk karir profesional.',
    icon: '🎮',
  },
  {
    title: 'Desain & Video',
    description: 'Produksi konten visual, grafis, dan video untuk kebutuhan esports.',
    icon: '🎨',
  },
  {
    title: 'Live Streaming',
    description: 'Layanan siaran langsung turnamen dan acara esports berkualitas tinggi.',
    icon: '📡',
  },
];

const upcomingEvents = [
  {
    title: 'RIKAS Championship Season 3',
    date: '12 Juli 2026',
    location: 'Semarang',
    game: 'Mobile Legends',
    badge: 'Pendaftaran Dibuka',
  },
  {
    title: 'Jawa Tengah Invitational',
    date: '25 Juli 2026',
    location: 'Solo',
    game: 'Valorant',
    badge: 'Segera',
  },
  {
    title: 'Kendal Esports Festival',
    date: '9 Agustus 2026',
    location: 'Kendal',
    game: 'Free Fire',
    badge: 'Coming Soon',
  },
];

const stats = [
  { value: '50+', label: 'Event Terselenggara' },
  { value: '3', label: 'Tahun Pengalaman' },
  { value: '100+', label: 'Partner & Sponsor' },
  { value: '10K+', label: 'Peserta Aktif' },
];
---

<BaseLayout title="Beranda">
  <Navbar slot="header" />

  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="container hero-content">
      <h1 class="hero-title">
        <span class="hero-title-main">RIKAS</span>
        <span class="hero-title-sub">INDO TECHNOLOGY</span>
      </h1>
      <p class="hero-tagline">Event & Komunitas Esports Jawa Tengah</p>
      <p class="hero-desc">
        Membangun ekosistem esports profesional di Jawa Tengah melalui
        event berkualitas, komunitas kuat, dan inovasi berkelanjutan.
      </p>
      <div class="hero-actions">
        <Button href="/events" variant="primary" size="lg">Lihat Event</Button>
        <Button href="/contact" variant="secondary" size="lg">Hubungi Kami</Button>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="section about">
    <div class="container">
      <div class="about-grid">
        <div class="about-text">
          <h2>Tentang <span class="text-accent">RIKAS</span></h2>
          <p class="mt-2">
            RIKAS INDO TECHNOLOGY adalah organisasi esports yang berpusat di Jawa Tengah,
            berkomitmen untuk mengembangkan bakat, menyelenggarakan kompetisi, dan
            membangun komunitas gamers yang positif dan profesional.
          </p>
          <p class="mt-2">
            Didirikan pada tahun 2023, kami telah berhasil menyelenggarakan lebih dari
            50 event di berbagai kota seperti Semarang, Solo, Kendal, dan Pati.
          </p>
        </div>
        <div class="stats-grid">
          {stats.map((stat) => (
            <div class="stat-item">
              <span class="stat-value">{stat.value}</span>
              <span class="stat-label">{stat.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="section services">
    <div class="container">
      <h2 class="text-center mb-4">Layanan <span class="text-accent">Kami</span></h2>
      <div class="services-grid">
        {services.map((s) => (
          <Card class="service-card">
            <span class="service-icon">{s.icon}</span>
            <h3 class="mt-2">{s.title}</h3>
            <p class="mt-1 text-sm">{s.description}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Events Preview Section -->
  <section class="section events-preview">
    <div class="container">
      <div class="flex justify-between items-center mb-4" style="flex-wrap: wrap; gap: 1rem;">
        <h2>Event <span class="text-accent">Mendatang</span></h2>
        <Button href="/events" variant="ghost" size="sm">Lihat Semua →</Button>
      </div>
      <div class="events-grid">
        {upcomingEvents.map((e) => (
          <Card class="event-card">
            <div class="flex justify-between items-center" style="flex-wrap: wrap; gap: 0.5rem;">
              <Badge variant="accent">{e.badge}</Badge>
              <Badge variant="muted">{e.game}</Badge>
            </div>
            <h3 class="mt-2">{e.title}</h3>
            <div class="event-meta mt-1">
              <span>📅 {e.date}</span>
              <span>📍 {e.location}</span>
            </div>
            <Button href={`/events`} variant="secondary" size="sm" class="mt-2">
              Lihat Detail
            </Button>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Sponsors Section -->
  <section class="section sponsors">
    <div class="container text-center">
      <h2 class="mb-4">Mitra & <span class="text-accent">Sponsor</span></h2>
      <div class="sponsors-bar">
        <div class="sponsor-placeholder">Logo Sponsor 1</div>
        <div class="sponsor-placeholder">Logo Sponsor 2</div>
        <div class="sponsor-placeholder">Logo Sponsor 3</div>
        <div class="sponsor-placeholder">Logo Sponsor 4</div>
        <div class="sponsor-placeholder">Logo Sponsor 5</div>
      </div>
    </div>
  </section>

  <!-- Contact CTA Section -->
  <section class="section contact-cta">
    <div class="container text-center">
      <h2>Siap Bergabung?</h2>
      <p class="mt-2" style="margin: 1rem auto 0;">
        Hubungi kami untuk informasi event, kerjasama, atau bergabung dengan komunitas.
      </p>
      <div class="hero-actions mt-3">
        <Button href="https://wa.me/6281234567890" variant="primary" size="lg">
          💬 WhatsApp
        </Button>
        <Button href="/contact" variant="secondary" size="lg">
          Formulir Kontak
        </Button>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* ── Hero ──────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 30% 50%, rgba(27, 42, 81, 0.6) 0%, transparent 70%),
                radial-gradient(ellipse at 70% 80%, rgba(249, 115, 22, 0.08) 0%, transparent 50%);
    z-index: 0;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding-top: 72px;
  }

  .hero-title {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }

  .hero-title-main {
    font-size: clamp(4rem, 12vw, 8rem);
    font-weight: 900;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  .hero-title-sub {
    font-size: clamp(1rem, 3vw, 2rem);
    font-weight: 600;
    letter-spacing: 0.3em;
    color: var(--color-accent);
    margin-top: 0.5rem;
  }

  .hero-tagline {
    font-size: clamp(1.1rem, 2.5vw, 1.5rem);
    color: var(--color-text-muted);
    margin-top: 1.5rem;
    max-width: none;
  }

  .hero-desc {
    font-size: 1rem;
    color: var(--color-text-muted);
    margin-top: 1rem;
    max-width: 50ch;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }

  /* ── About ─────────────────────────────────────────── */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .about-text h2 {
    font-size: clamp(1.75rem, 3vw, 2.25rem);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-align: center;
  }

  .stat-value {
    font-size: 2.5rem;
    font-weight: 900;
    color: var(--color-accent);
  }

  .stat-label {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-top: 0.25rem;
  }

  /* ── Services ──────────────────────────────────────── */
  .services {
    background: var(--color-bg-alt);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .service-card {
    text-align: center;
  }

  .service-icon {
    font-size: 2.5rem;
    display: block;
  }

  .service-card h3 {
    font-size: 1.1rem;
  }

  /* ── Events ────────────────────────────────────────── */
  .events-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .event-meta {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  /* ── Sponsors ──────────────────────────────────────── */
  .sponsors {
    background: var(--color-bg-alt);
  }

  .sponsors-bar {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
    margin-top: 1rem;
  }

  .sponsor-placeholder {
    padding: 1rem 2rem;
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  /* ── Contact CTA ───────────────────────────────────── */
  .contact-cta {
    background: radial-gradient(ellipse at center, rgba(249, 115, 22, 0.08) 0%, transparent 70%);
  }

  /* ── Responsive ────────────────────────────────────── */
  @media (max-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .events-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .services-grid,
    .events-grid {
      grid-template-columns: 1fr;
    }

    .hero {
      min-height: 90vh;
    }
  }
</style>
