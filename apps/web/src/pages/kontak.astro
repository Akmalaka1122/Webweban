---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/brand/Navbar.astro';
import Footer from '../components/brand/Footer.astro';
import Button from '../components/ui/Button.astro';
---

<BaseLayout title="Kontak" description="Hubungi RIKAS INDO TECHNOLOGY — Partnership, Talent, Event Booking, dan pertanyaan umum">
  <Navbar slot="header" />

  <section class="section">
    <div class="container">
      <h1>Hubungi <span class="text-accent">Kami</span></h1>
      <p class="mt-1">Kirim pesan untuk kerjasama, pendaftaran talent, atau pertanyaan event.</p>

      <div class="contact-grid mt-4">
        <form id="contact-form" class="contact-form" novalidate>
          <div class="form-group">
            <label for="name">Nama Lengkap *</label>
            <input type="text" id="name" name="name" required placeholder="Nama Anda" />
            <span class="error-msg" data-for="name"></span>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" placeholder="email@contoh.com" />
            </div>
            <div class="form-group">
              <label for="whatsapp">WhatsApp</label>
              <input type="text" id="whatsapp" name="whatsapp" placeholder="0812xxxx" />
            </div>
          </div>

          <div class="form-group">
            <label for="type">Jenis Pesan *</label>
            <select id="type" name="type" required>
              <option value="">Pilih jenis pesan...</option>
              <option value="partnership">Partnership / Sponsor</option>
              <option value="talent">Lamaran Talent</option>
              <option value="event">Booking Event</option>
              <option value="general">Pertanyaan Umum</option>
            </select>
            <span class="error-msg" data-for="type"></span>
          </div>

          <div class="form-group">
            <label for="message">Pesan *</label>
            <textarea id="message" name="message" rows="5" required placeholder="Tuliskan pesan Anda..."></textarea>
            <span class="error-msg" data-for="message"></span>
          </div>

          <!-- Honeypot -->
          <div style="position:absolute;left:-9999px" aria-hidden="true">
            <input type="text" name="website" tabindex="-1" autocomplete="off" />
          </div>

          <Button type="submit" variant="primary" size="lg">Kirim Pesan</Button>
        </form>

        <div class="contact-info">
          <div class="info-card">
            <h3>Kontak Langsung</h3>
            <ul>
              <li>💬 <a href="https://wa.me/6281234567890" target="_blank" rel="noopener">WhatsApp: 0812-3456-7890</a></li>
              <li>📧 <a href="mailto:info@rikas.id">info@rikas.id</a></li>
              <li>📸 <a href="https://instagram.com/rikas.idn" target="_blank" rel="noopener">@rikas.idn</a></li>
            </ul>
          </div>

          <div class="info-card">
            <h3>Area Layanan</h3>
            <ul>
              <li>📍 Semarang</li>
              <li>📍 Solo</li>
              <li>📍 Kendal</li>
              <li>📍 Pati</li>
            </ul>
          </div>
        </div>
      </div>

      <div id="form-success" class="success-msg" style="display:none;">
        <h3>✅ Pesan Terkirim!</h3>
        <p>Terima kasih, kami akan membalas dalam 1×24 jam.</p>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<script>
const form = document.getElementById('contact-form');
const success = document.getElementById('form-success');

form?.addEventListener('submit', async (e) => {
  e.preventDefault();
  // Clear errors
  form.querySelectorAll('.error-msg').forEach(el => el.textContent = '');
  form.querySelectorAll('.error').forEach(el => el.classList.remove('error'));

  const data = Object.fromEntries(new FormData(form));
  // Honeypot check
  if (data.website) return;

  // Client validation
  let valid = true;
  if (!data.name?.trim()) { showErr('name', 'Nama wajib diisi'); valid = false; }
  if (!data.type) { showErr('type', 'Pilih jenis pesan'); valid = false; }
  if (!data.message?.trim()) { showErr('message', 'Pesan wajib diisi'); valid = false; }
  if (!valid) return;

  try {
    const res = await fetch('/api/contact', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data),
    });
    if (res.ok) {
      form.style.display = 'none';
      success.style.display = 'block';
    } else {
      alert('Gagal mengirim. Silakan coba lagi.');
    }
  } catch {
    alert('Gagal mengirim. Periksa koneksi internet.');
  }
});

function showErr(field: string, msg: string) {
  const el = form.querySelector(`[data-for="${field}"]`);
  if (el) el.textContent = msg;
  const input = form.querySelector(`[name="${field}"]`);
  if (input) input.classList.add('error');
}
</script>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 3rem;
  }
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .form-group label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-muted);
  }
  .form-group input,
  .form-group select,
  .form-group textarea {
    padding: 0.75rem 1rem;
    background: var(--color-glass);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    color: var(--color-text);
    font-size: 0.95rem;
    transition: border-color 0.2s;
  }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-accent);
  }
  .form-group input.error,
  .form-group select.error,
  .form-group textarea.error {
    border-color: #ef4444;
  }
  .error-msg {
    font-size: 0.8rem;
    color: #ef4444;
    min-height: 1.2em;
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .info-card {
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
  }
  .info-card h3 {
    font-size: 1rem;
    margin-bottom: 1rem;
  }
  .info-card ul {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    list-style: none;
    padding: 0;
  }
  .info-card a {
    color: var(--color-text-muted);
    transition: color 0.2s;
  }
  .info-card a:hover {
    color: var(--color-accent);
  }
  .success-msg {
    text-align: center;
    padding: 3rem;
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.3);
    border-radius: var(--radius-lg);
    color: #22c55e;
  }
  .success-msg p {
    color: var(--color-text-muted);
    margin-top: 0.5rem;
  }
  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>
