---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/brand/Navbar.astro';
import Footer from '../../components/brand/Footer.astro';
import Button from '../../components/ui/Button.astro';
---

<BaseLayout title="Terima Kasih" description="Pesan Anda berhasil dikirim ke RIKAS INDO TECHNOLOGY">
  <Navbar slot="header" />

  <section class="section">
    <div class="container text-center">
      <div class="thank-you">
        <span class="thank-you-icon">✅</span>
        <h1>Terima <span class="text-accent">Kasih</span></h1>
        <p class="mt-2">Pesan Anda berhasil dikirim. Kami akan merespons dalam 1×24 jam.</p>
        <div class="mt-3">
          <Button href="/" variant="primary">Kembali ke Beranda</Button>
          <Button href="https://wa.me/6281234567890" variant="secondary">💬 WhatsApp Langsung</Button>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .thank-you {
    max-width: 500px;
    margin: 4rem auto;
  }
  .thank-you-icon {
    font-size: 4rem;
    display: block;
    margin-bottom: 1rem;
  }
  .thank-you p {
    max-width: none;
    margin: 0 auto;
  }
</style>
