---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/brand/Navbar.astro';
import Footer from '../../components/brand/Footer.astro';
import EventCard from '../../components/events/EventCard.astro';
import EventFilters from '../../components/events/EventFilters.astro';
import Badge from '../../components/ui/Badge.astro';
import { getEvents } from '../../lib/cms';

const gameFilter = Astro.url.searchParams.get('game');
const tab = Astro.url.searchParams.get('tab') || 'upcoming';

let events: any[] = [];
try {
  const res = await getEvents({ limit: 50 });
  events = res.docs || [];
} catch {
  // CMS not available — show empty state
}

const now = new Date();
let filtered = events;
if (gameFilter && gameFilter !== 'Semua') {
  filtered = filtered.filter(e => e.game === gameFilter);
}
const upcoming = filtered.filter(e => !e.status || e.status === 'upcoming' || e.status === 'ongoing');
const past = filtered.filter(e => e.status === 'completed' || e.status === 'cancelled');
const display = tab === 'past' ? past : upcoming;
---

<BaseLayout title="Event" description="Daftar event esports RIKAS INDO TECHNOLOGY — turnamen Mobile Legends, Free Fire, PUBG, Valorant di Jawa Tengah">
  <Navbar slot="header" />

  <section class="section">
    <div class="container">
      <h1>Event <span class="text-accent">RIKAS</span></h1>
      <p class="mt-1">Temukan turnamen dan event esports terbaru kami.</p>

      <div class="tabs mt-3">
        <a href="/event?tab=upcoming" class:list={['tab', { active: tab === 'upcoming' }]}>Mendatang</a>
        <a href="/event?tab=past" class:list={['tab', { active: tab === 'past' }]}>Selesai</a>
      </div>

      <div class="mt-3">
        <EventFilters active={gameFilter || 'Semua'} />
      </div>

      {display.length === 0 ? (
        <div class="empty-state">
          <p>Belum ada event {tab === 'past' ? 'selesai' : 'mendatang'} yang tersedia.</p>
        </div>
      ) : (
        <div class="events-grid">
          {display.map((e) => (
            <EventCard
              title={e.title}
              slug={e.slug}
              game={e.game}
              date={e.date}
              location={e.location}
              status={e.status}
              prize_pool={e.prize_pool}
              featured_image={e.featured_image}
            />
          ))}
        </div>
      )}
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .tabs {
    display: flex;
    gap: 0.5rem;
  }
  .tab {
    padding: 0.5rem 1.5rem;
    font-weight: 600;
    font-size: 0.9rem;
    border-radius: var(--radius);
    color: var(--color-text-muted);
    transition: all 0.2s;
    text-decoration: none;
  }
  .tab.active {
    background: var(--color-accent);
    color: #fff;
  }
  .tab:hover:not(.active) {
    background: var(--color-glass);
    color: var(--color-text);
  }
  .events-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 1.5rem;
  }
  .empty-state {
    text-align: center;
    padding: 4rem 1rem;
    color: var(--color-text-muted);
  }
  @media (max-width: 1024px) {
    .events-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .events-grid { grid-template-columns: 1fr; }
  }
</style>
